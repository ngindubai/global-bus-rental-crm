# Copy to .env and fill in. See SETUP-TASKS.html for how to obtain each value.
DATABASE_URL="postgresql://gbr:gbr_dev_pw@localhost:5433/gbr_crm?schema=public"
JWT_SECRET="change-me-in-production-long-random-string"

# Initial administrator bootstrap (used by prisma/seed.js). In production set a
# strong INITIAL_ADMIN_PASSWORD; if left blank the seed generates a random one and
# prints it once to the console. The admin is only created if it does not exist —
# an existing admin's password is never reset.
INITIAL_ADMIN_EMAIL="admin@globalbusrental.com"
INITIAL_ADMIN_PASSWORD=""

# Seed demo leads/bookings/suppliers and the manager/agent/finance demo accounts.
# Defaults to true outside production; MUST stay false/unset in production.
SEED_SAMPLE_DATA="true"

VONAGE_API_KEY=""
VONAGE_API_SECRET=""
VONAGE_APPLICATION_ID=""
VONAGE_SIGNATURE_SECRET=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

FX_API_KEY=""
FX_PROVIDER="exchangerate-api"
BASE_CURRENCY="USD"

ANTHROPIC_API_KEY=""
AI_MODEL="claude-opus-4-8"
